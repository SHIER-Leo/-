# Current provider: zenmux | openai
LLM_PROVIDER=zenmux

# Fill in the key for the selected provider. Never put it in the HTML file.
LLM_API_KEY=

# ZenMux defaults
LLM_BASE_URL=https://zenmux.ai/api/v1
LLM_MODEL=openai/gpt-5.6-terra
PORT=3000

# Public address used in invitation links. Local development default is http://localhost:3000.
PUBLIC_BASE_URL=http://localhost:3000

# API base embedded in a generated H5 invitation. Keep /api for same-domain deployment.
H5_API_BASE_URL=/api

# Leave blank when the H5 and API are served from the same domain.
# When they are deployed separately, set the exact H5 origin, for example https://demo.example.com.
CORS_ORIGIN=
